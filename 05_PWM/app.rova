 * Program: 05_PWM (C style)
 * Platform: CH32V003 / Rovari SDK
 * Hardware: LED on PD2 (TIM1 CH1) via 1k resistor
 */

#include "rovari.h"

void app_init()
{
    pwm_init(PD2, 1000);
}

void app_run()
{
    for (uint8_t i = 0; i < 255; i++)
    {
        pwm_write(PD2, i);
        delay(10);
    }

    for (int i = 255; i >= 0; i--)
    {
        pwm_write(PD2, (uint8_t)i);
        delay(10);
    }
}