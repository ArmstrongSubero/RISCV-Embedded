 * Program:  02_Pushbutton (C++ style)
 * Platform: CH32V003 / Rovari SDK
 * Hardware: LED on PC1 via 1k resistor
 *           pushbutton on PC2 to GND
 */

#include "rovari.h"

Gpio led(PC1, Output);
Button btn(PC2);

void app_init()
{
}

void app_run()
{
    if (btn.pressed())
    {
        led.toggle();
    }
}