 * Program: 14_Watchdog (C style)
 * Platform: CH32V003 / Rovari SDK
 * Hardware: LED on PC1 via 1k resistor
 */
#include "rovari.h"

#define FEED 0

void app_init() {
  pin_mode(PC1, Output);

  for (uint8_t i = 0; i < 3; i++) {
    digital_write(PC1, High);
    delay(80);
    digital_write(PC1, Low);
    delay(80);
  }

  iwdg_start(4000);
}

void app_run() {
  pin_toggle(PC1);
  delay(200);

  #if FEED
    iwdg_feed();
  #endif
}