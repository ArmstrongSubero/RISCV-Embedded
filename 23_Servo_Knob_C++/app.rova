 *
 * Program: 23_ServoKnob (C++ style)
 * Platform: CH32V003 / Rovari SDK
 * Hardware: servo on PD2 (TIM1 CH1)
 *           potentiometer on PA1 (ADC ch1)
 */

#include "rovari.h"

Servo s(PD2);
Adc knob(PA1);

void app_init()
{
}

void app_run()
{
    uint16_t raw = knob.read();
    uint16_t deg = (uint16_t)((raw * 180UL) / 1023UL);

    s.writeDeg(deg);
    delay(15);
}