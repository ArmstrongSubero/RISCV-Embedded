 * Program: 03_BlinkWithoutDelay (C++ style)
 * Platform: CH32V003 / Rovari SDK
 * Hardware: LED on PC1 via 1k resistor
 */

#include "rovari.h" 

Gpio led(PC1, Output);
uint32_t last_toggle = 0;

void app_init()
{
    
}

void app_run()
{
    if (millis() - last_toggle >= 500)
    {
        last_toggle = millis();
        led.toggle();
    }
}