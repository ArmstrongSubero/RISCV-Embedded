# Force LF for source files (consistent builds across platforms)
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.rova text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.blocks text eol=lf
*.ld text eol=lf
*.S text eol=lf

# Binary files
*.bin binary
*.elf binary
*.hex binary
*.o binary
*.pdf binary
*.png binary
*.jpg binary
*.webp binary
